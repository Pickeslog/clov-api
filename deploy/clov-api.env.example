# systemd EnvironmentFile 템플릿 → /opt/clov-api/clov-api.env 로 복사해 값 확정.
# 여기엔 "배포 비-시크릿"만. 진짜 시크릿(DB 비번·OAuth secret·JWT·R2 키)은
# /opt/clov-api/application-secret.yaml 에 둔다(application-secret.example.yaml 참고).

# CORS 허용 오리진(프론트 도메인). 단일 오리진이라 사실상 same-origin이지만 명시.
APP_CORS_ALLOWED_ORIGINS=https://clovlabcalss.store

# 소셜 로그인 후 프론트 복귀 URL
APP_OAUTH2_REDIRECT_URL=https://clovlabcalss.store/oauth2/redirect

# provider가 돌려보낼 공개 콜백의 베이스(= 공개 도메인). 실제 콜백은 {base}/login/oauth2/code/{provider}
APP_OAUTH_REDIRECT_BASE=https://clovlabcalss.store
